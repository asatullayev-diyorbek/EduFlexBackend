# EduFlex Backend — muhit o'zgaruvchilari namunasi
# Ushbu faylni nusxa olib .env nomiga saqlang va qiymatlarni o'zgartiring

# Django maxfiy kalit (production uchun murakkab qiymat tanlang)
SECRET_KEY=your-secret-key-change-this-in-production

# Debug rejimi (production da False bo'lishi shart)
DEBUG=True

# Ruxsat etilgan hostlar (vergul bilan ajratilib yoziladi)
ALLOWED_HOSTS=localhost,127.0.0.1

# Ma'lumotlar bazasi (hozir SQLite, production da PostgreSQL tavsiya etiladi)
DATABASE_URL=sqlite:///db.sqlite3

# Frontend URL (CORS uchun)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
